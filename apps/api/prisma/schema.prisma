generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  EMPLOYEE
  CUSTOMER
}

enum VehicleStatus {
  AVAILABLE
  RESERVED
  RENTED
  SERVICE
  RETIRED
}

enum FuelType {
  PETROL
  DIESEL
  LPG
  HYBRID
  ELECTRIC
}

enum TransmissionType {
  MANUAL
  AUTOMATIC
}

enum InsuranceCoverageType {
  OC
  AC
  NNW
}

enum RentalStatus {
  DRAFT
  ACTIVE
  EXTENDED
  RETURNED
}

model User {
  id               String    @id @default(uuid())
  email            String    @unique
  name             String
  role             UserRole  @default(EMPLOYEE)
  passwordHash     String?
  setupToken       String?
  setupTokenExpiry DateTime?
  isActive         Boolean   @default(true)
  failedAttempts   Int       @default(0)
  lockedUntil      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  auditLogs AuditLog[] @relation("AuditActor")
  rentals   Rental[]   @relation("RentalCreatedBy")

  @@map("users")
}

model AuditLog {
  id          String   @id @default(uuid())
  actorId     String?
  action      String
  entityType  String
  entityId    String
  changesJson Json     @default("{}")
  ipAddress   String?
  createdAt   DateTime @default(now())

  actor User? @relation("AuditActor", fields: [actorId], references: [id])

  @@index([entityType, entityId])
  @@index([actorId])
  @@index([createdAt])
  @@map("audit_logs")
}

model Vehicle {
  id              String            @id @default(uuid())
  registration    String            @unique
  vin             String            @unique
  make            String
  model           String
  year            Int
  color           String?
  fuelType        FuelType
  transmission    TransmissionType
  seatCount       Int               @default(5)
  mileage         Int               @default(0)
  notes           String?
  status          VehicleStatus     @default(AVAILABLE)
  photoKey        String?
  isArchived      Boolean           @default(false)

  insurance       VehicleInsurance?
  inspection      VehicleInspection?
  documents       VehicleDocument[]
  rentals         Rental[]

  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([status])
  @@index([make, model])
  @@map("vehicles")
}

model VehicleInsurance {
  id            String                @id @default(uuid())
  vehicleId     String                @unique
  companyName   String
  policyNumber  String
  expiryDate    DateTime
  coverageType  InsuranceCoverageType
  documentKey   String?

  vehicle       Vehicle               @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@map("vehicle_insurance")
}

model VehicleInspection {
  id            String    @id @default(uuid())
  vehicleId     String    @unique
  expiryDate    DateTime
  documentKey   String?

  vehicle       Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@map("vehicle_inspections")
}

model VehicleDocument {
  id            String    @id @default(uuid())
  vehicleId     String
  label         String
  fileKey       String
  fileName      String
  mimeType      String
  uploadedAt    DateTime  @default(now())

  vehicle       Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
  @@map("vehicle_documents")
}

model Customer {
  id                    String    @id @default(uuid())
  firstName             String
  lastName              String
  phone                 String
  email                 String?
  address               String?

  peselEncrypted        Json
  peselHmac             String
  idNumberEncrypted     Json
  idNumberHmac          String
  licenseNumEncrypted   Json
  licenseNumHmac        String

  idIssuedBy            String?
  idIssuedDate          DateTime?
  licenseCategory       String?
  licenseIssuedBy       String?

  retentionExpiresAt    DateTime?
  isArchived            Boolean   @default(false)

  rentals               Rental[]

  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([peselHmac])
  @@index([lastName, firstName])
  @@index([phone])
  @@map("customers")
}

model Rental {
  id              String        @id @default(uuid())
  vehicleId       String
  customerId      String
  createdById     String
  startDate       DateTime
  endDate         DateTime
  status          RentalStatus  @default(DRAFT)
  dailyRateNet    Int
  totalPriceNet   Int
  totalPriceGross Int
  vatRate         Int           @default(23)
  handoverData    Json?
  returnData      Json?
  returnMileage   Int?
  notes           String?
  overrodeConflict Boolean      @default(false)

  vehicle         Vehicle       @relation(fields: [vehicleId], references: [id])
  customer        Customer      @relation(fields: [customerId], references: [id])
  createdBy       User          @relation("RentalCreatedBy", fields: [createdById], references: [id])

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([vehicleId])
  @@index([customerId])
  @@index([status])
  @@index([startDate, endDate])
  @@map("rentals")
}
