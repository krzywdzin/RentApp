# Database
DATABASE_URL=postgresql://user:password@localhost:5432/rentapp?sslmode=require

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
PORTAL_JWT_SECRET=change-me-portal-secret-min-32-chars

# Field encryption (32 bytes hex = 64 hex chars)
FIELD_ENCRYPTION_KEY=REPLACE_WITH_64_HEX_CHARS__run__openssl_rand_-hex_32

# Mail (Mailpit in dev)
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_FROM=noreply@rentapp.local
# MAIL_USER=     # SMTP username (required in production)
# MAIL_PASS=     # SMTP password (required in production)

# Company details (used in contract PDFs)
COMPANY_NAME=KITEK
COMPANY_OWNER=Pawel Romanowski
COMPANY_ADDRESS=ul. Sieradzka 18, 87-100 Torun
COMPANY_PHONE=535 766 666 / 602 367 100

# App
APP_URL=http://localhost:3000
PORT=3000
NODE_ENV=development

# Storage: S3-compatible (MinIO for dev, Cloudflare R2 for production)
# For R2: S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# For R2: S3_ACCESS_KEY=<R2 access key ID>
# For R2: S3_SECRET_KEY=<R2 secret access key>
S3_ENDPOINT=http://localhost:9000
S3_REGION=auto
S3_BUCKET=rentapp
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# SMSAPI
SMSAPI_TOKEN=your-smsapi-token
SMSAPI_TEST_MODE=true
SMSAPI_SENDER_NAME=RentApp
